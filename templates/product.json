          }
        },
        "ig_step3": {
          "type": "slide",
          "settings": {
            "title": "3. Trim & Finish",
            "heading_size": "h1",
            "description": "<p>Use a box cutter or utility knife to trim panels around outlets, corners, and edges. Optional: paint with any standard wall paint to match your color scheme. That's it — you're done.</p>",
            "text_size": "typeset2",
