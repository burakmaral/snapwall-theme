    "product-faq": {
      "type": "faq",
      "blocks": {
        "pf_q1": {
          "type": "question",
          "settings": {
            "title": "How do I install these panels?",
            "text": "<p>Apply construction adhesive to the back of each panel and press onto a clean, dry wall — or fix with screws for extra hold. Use a utility knife to cut panels to size. Most walls are completed in one afternoon.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "pf_q2": {
          "type": "question",
          "settings": {
            "title": "Can I paint the panels?",
            "text": "<p>Yes! Our panels accept any standard interior wall paint. Use a roller or spray paint for the best finish. This lets you match any color scheme perfectly.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "pf_q3": {
          "type": "question",
          "settings": {
            "title": "Are the panels moisture resistant?",
            "text": "<p>Yes. Our high-density polystyrene panels are water-resistant and suitable for kitchens, bathrooms, and humid environments. They won't warp, rot, or develop mold.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "pf_q4": {
          "type": "question",
          "settings": {
            "title": "How do I replace a damaged panel?",
            "text": "<p>Use a chisel or oscillating tool to carefully remove the damaged panel and scrape off old adhesive. Clean the surface, apply fresh construction adhesive to the replacement panel, and press into place. Some touch-up painting may be needed afterward.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "pf_q5": {
          "type": "question",
          "settings": {
            "title": "How long does shipping take?",
            "text": "<p>Manufacturing takes 2-3 days and delivery generally takes 3-5 business days. Free shipping to US and EU. US, UK, EU, and Canada residents do not pay customs fees or import taxes.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "pf_q6": {
          "type": "question",
          "settings": {
            "title": "What is your return policy?",
            "text": "<p>We offer a 30-day return policy. If you're not completely satisfied, contact us and we'll guide you through the return process.</p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        }
      },
