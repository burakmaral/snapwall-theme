            "icon": "clipboard",
            "heading": "Product Details",
            "content": "<p><strong>Material:</strong> High-density expanded polystyrene (EPS)<br/><strong>Panel Size:</strong> 100 cm × 50 cm (0.5 m² per panel)<br/><strong>Thickness:</strong> 2–2.5 cm of solid architectural depth<br/><strong>Weight:</strong> Ultra-lightweight, approx. 100–200 g per panel<br/><strong>Fire Rating:</strong> Self-extinguishing material<br/><strong>Moisture Resistance:</strong> Water-resistant — suitable for kitchens, bathrooms, and outdoor use</p>",
            "page": "",
            "custom_liquid": "",
            "keep_open": false
          }
        },
        "collapsible_tab_thickness": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "ruler",
            "heading": "2.5 cm Architectural Depth",
            "content": "<p>Each panel is 2–2.5 cm of solid material — genuine 3D depth, not a flat print or peel-and-stick surface. The raised pattern creates real shadow lines that shift with light, giving your wall the appearance of authentic masonry. This is not wallpaper.</p>",
            "page": "",
            "custom_liquid": "",
            "keep_open": true
          }
        },
        "collapsible_tab_install": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "check_mark",
            "heading": "Installation Guide",
            "content": "<p><strong>Step 1:</strong> Clean and dry your wall surface.<br/><strong>Step 2:</strong> Apply construction adhesive to the back of each panel.<br/><strong>Step 3:</strong> Press firmly onto the wall and hold for 30 seconds.</p><p><em>Trim panels with a utility knife at edges. Optional: fix with screws for extra hold. Paint with any standard wall paint for a custom finish.</em></p>",
            "page": "",
            "custom_liquid": "",
            "keep_open": false
          }
        },
