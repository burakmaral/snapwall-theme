    "install_guide": {
      "type": "dual-scroll",
      "blocks": {
        "ig_step1": {
          "type": "slide",
          "settings": {
            "title": "1. Prepare Your Wall",
            "heading_size": "h1",
            "description": "<p>Clean and dry your wall surface. Ensure it is smooth and free of dust, grease, or loose paint. A clean surface ensures the strongest adhesive bond.<\/p>",
            "text_size": "typeset2",
            "secondary_color": false,
            "enable_highlight": false,
            "highlight_style": "marker",
            "button_label": "",
            "button_size": "medium",
            "media_background_color": "#f0ebe3"
          }
        },
        "ig_step2": {
          "type": "slide",
          "settings": {
            "title": "2. Apply Adhesive & Press",
            "heading_size": "h1",
            "description": "<p>Apply construction adhesive to the back of each panel in a zigzag pattern. Press firmly onto the wall and hold for 30 seconds. Align edges with adjacent panels as you go.<\/p>",
            "text_size": "typeset2",
            "secondary_color": false,
            "enable_highlight": false,
            "highlight_style": "marker",
            "button_label": "",
            "button_size": "medium",
            "media_background_color": "#f0ebe3"
          }
        },
        "ig_step3": {
          "type": "slide",
          "settings": {
            "title": "3. Trim & Finish",
            "heading_size": "h1",
            "description": "<p>Use a box cutter or utility knife to trim panels around outlets, corners, and edges. Optional: paint with any standard wall paint to match your color scheme. That's it \u2014 you're done.<\/p>",
            "text_size": "typeset2",
            "secondary_color": false,
            "enable_highlight": false,
            "highlight_style": "marker",
            "button_label": "",
            "button_size": "medium",
            "media_background_color": "#f0ebe3"
          }
        }
      },
      "block_order": ["ig_step1", "ig_step2", "ig_step3"],
      "settings": {
