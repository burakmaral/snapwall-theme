          "settings": {
            "icon": "truck",
            "heading": "Shipping Info",
            "content": "<p>Manufacturing takes 2-3 days. Delivery generally takes 3-5 business days. Free shipping to the US and EU. Panels ship flat and lightweight. US, UK, EU, and Canada residents do not pay customs fees or import taxes.</p>",
            "page": "",
