    "homepage_faq": {
      "type": "faq",
      "blocks": {
        "faq_q1": {
          "type": "question",
          "settings": {
            "title": "How do I install the panels?",
            "text": "<p>Our panels are fixed permanently with construction adhesive or screws. Simply measure, cut to fit with a utility knife, apply adhesive, and press onto your clean, dry wall. Most rooms are completed in one afternoon.<\/p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "faq_q2": {
          "type": "question",
          "settings": {
            "title": "Are the panels fire-rated and safe?",
            "text": "<p>Yes. Our polystyrene panels are classified as self-extinguishing material. They meet standard safety requirements for interior wall coverings and are suitable for residential and commercial use.<\/p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "faq_q3": {
          "type": "question",
          "settings": {
            "title": "Can I paint the panels?",
            "text": "<p>Absolutely. Our panels accept any standard interior wall paint. Use a roller or spray paint for best results. This lets you match any color scheme or design vision perfectly.<\/p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "faq_q4": {
          "type": "question",
          "settings": {
            "title": "How durable are styrofoam panels?",
            "text": "<p>Our high-density polystyrene panels are impact-resistant, moisture-resistant, and designed to last. They won't warp, rot, or fade. For high-traffic areas, we recommend a coat of paint for extra protection.<\/p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "faq_q5": {
          "type": "question",
          "settings": {
            "title": "What sizes are available?",
            "text": "<p>Our standard panel size is 100cm x 50cm (0.5 m\u00b2 per panel). Use our coverage calculator on any product page to find exactly how many panels you need for your wall.<\/p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "faq_q6": {
          "type": "question",
          "settings": {
            "title": "Do you ship internationally?",
            "text": "<p>Yes! We offer free shipping to the US and EU. We also ship worldwide. Manufacturing takes 2-3 days and delivery generally takes 3-5 business days. US, UK, EU, and Canada residents do not pay customs fees.<\/p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "faq_q7": {
          "type": "question",
          "settings": {
            "title": "Can I return my panels?",
            "text": "<p>We offer a 30-day return policy. If you're not satisfied, email us and we'll walk you through the return process. We always aim to make sure our customers love their purchase.<\/p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "faq_q8": {
          "type": "question",
          "settings": {
            "title": "How do I replace a damaged panel?",
            "text": "<p>Use a chisel or oscillating tool to carefully remove the damaged panel and scrape off old adhesive. Clean the wall surface, then apply fresh construction adhesive to the replacement panel and press into place. Some touch-up painting may be needed afterward.<\/p>",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        }
      },
      "block_order": ["faq_q1", "faq_q2", "faq_q3", "faq_q4", "faq_q5", "faq_q6", "faq_q7", "faq_q8"],
