{% comment %}
  Snapwall transformation section updates:
  - adds editorial wrapper classes for the homepage before/after story block
  - introduces graceful fallback panels when comparison images are not assigned
  - disables the draggable handle in fallback mode so the section reads as a static split layout
{% endcomment %}
{%- liquid
  assign before_image = section.blocks | first
  assign after_image = section.blocks | last
  assign image_ratio_percent = 38
  assign before_title = 'Before'
  assign after_title = 'After'
  assign has_full_comparison = false

  if before_image != blank
    assign before_title = before_image.settings.title | default: 'Before'
  endif

  if after_image != blank
    assign after_title = after_image.settings.title | default: 'After'
  endif

  if before_image != blank and after_image != blank and before_image.settings.image != blank and after_image.settings.image != blank
    assign has_full_comparison = true
  endif

  if before_image != blank
    assign image_ratio_percent = 1 | divided_by: before_image.settings.image.aspect_ratio | times: 100
  elsif after_image != blank
    assign image_ratio_percent = 1 | divided_by: after_image.settings.image.aspect_ratio | times: 100
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --image-ratio-percent: {{ image_ratio_percent }}%;
    --color-highlight: {{ section.settings.colors_highlight.red }}, {{ section.settings.colors_highlight.green }}, {{ section.settings.colors_highlight.blue }};
  }
  {%- if before_image.settings.image_mobile != blank and section.settings.mobile_image_ratio == 'adapt' %}
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} {
        --image-ratio-percent: {{ 1 | divided_by: before_image.settings.image_mobile.aspect_ratio | times: 100 }}%;
      }
    }  
  {% endif -%}

  #shopify-section-{{ section.id }} .image-comparison {
    --color-border: {{ section.settings.colors_line.red }}, {{ section.settings.colors_line.green }}, {{ section.settings.colors_line.blue }};
  }
{%- endstyle -%}

{{ 'section-image-comparison.css' | asset_url | stylesheet_tag }}

<div class="section--padding image-comparison-section image-comparison-section--editorial{% if section.settings.show_divider %} section--divider{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full-width{% endif %}">
    <div class="title-wrapper image-comparison-section__header{% if section.settings.heading == blank %} title-wrapper--no-heading{% endif %}{% if section.settings.full_width %} page-width{% endif %} {{ section.settings.heading_alignment }}" data-reveal>
      <{{ section.settings.heading_tag }} class="title {{ section.settings.heading_size }}">
        {%- capture _hl_em -%}<em class="highlighted-text" is="highlighted-text" data-style="heavy-squiggle">Transformation{%- render 'icon-scribble', icon: 'heavy-squiggle' -%}</em>{%- endcapture -%}
        {%- assign _hl_heading = section.settings.heading | replace: 'Transformation', _hl_em -%}
        <use-animate>{{- _hl_heading -}}</use-animate>
      </{{ section.settings.heading_tag }}>
    </div>

    <image-comparison class="image-comparison image-comparison--editorial{% unless has_full_comparison %} image-comparison--static{% endunless %}" data-layout="{{ section.settings.layout }}">
      <span class="image-comparison__animate"></span>
      {%- capture sizes -%}{% if section.settings.full_width %}100vw{% else %}(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px) calc(100vw - 10rem), 100vw{% endif %}{%- endcapture -%}
      
      {%- if before_image != blank -%}
        <div class="image-comparison__before image-comparison__item--{{ before_image.settings.title_position }} media-wrapper" {{ before_image.shopify_attributes }}>
          <div class="image-comparison__panel image-comparison__panel--before">
            <p class="image-comparison__title h3 button button--{{ before_image.settings.title_size }} small-hide">
              {%- render 'highlight-text', 
                  hl_input: before_title, 
                  hl_style: before_image.settings.highlight_style,
                  hl_enable: before_image.settings.enable_highlight,
                  hl_animateWrap: true -%}
            </p>

            {%- if before_image.settings.image != blank -%}
              <div class="image-comparison__media media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
                {%- liquid
                  if before_image.settings.image_mobile == blank
                    echo before_image.settings.image | image_url: width: 3840 | image_tag: loading: 'lazy', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', is: 'lazy-image'
                  else
                    echo before_image.settings.image_mobile | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'medium-hide large-up-hide', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', is: 'lazy-image'
                    echo before_image.settings.image | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'small-hide', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', is: 'lazy-image'
                  endif
                -%}
              </div>
            {%- else -%}
              <div class="image-comparison__media media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }} comparison-placeholder comparison-placeholder--before">
                <div class="comparison-placeholder__inner">
                  <span class="comparison-placeholder__eyebrow">{{ before_title }}</span>
                  <span class="comparison-placeholder__headline">Plain wall</span>
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- if after_image != blank -%}
        <div class="image-comparison__after image-comparison__item--{{ after_image.settings.title_position }} media-wrapper" {{ after_image.shopify_attributes }}>
          <div class="image-comparison__panel image-comparison__panel--after">
            <p class="image-comparison__title h3 button button--{{ after_image.settings.title_size }} small-hide">
              {%- render 'highlight-text', 
                  hl_input: after_title, 
                  hl_style: after_image.settings.highlight_style,
                  hl_enable: after_image.settings.enable_highlight,
                  hl_animateWrap: true -%}
            </p>

            {%- if after_image.settings.image != blank -%}
              <div class="image-comparison__media media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }}">
                {%- liquid
                  if after_image.settings.image_mobile == blank
                    echo after_image.settings.image | image_url: width: 3840 | image_tag: loading: 'lazy', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', is: 'lazy-image'
                  else
                    echo after_image.settings.image_mobile | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'medium-hide large-up-hide', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', is: 'lazy-image'
                    echo after_image.settings.image | image_url: width: 3840 | image_tag: loading: 'lazy', class: 'small-hide', sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', is: 'lazy-image'
                  endif
                -%}
              </div>
            {%- else -%}
              <div class="image-comparison__media media media--{{ section.settings.image_ratio }} media-mobile--{{ section.settings.mobile_image_ratio }} comparison-placeholder comparison-placeholder--after">
                <div class="comparison-placeholder__inner">
                  <span class="comparison-placeholder__eyebrow">{{ after_title }}</span>
                  <span class="comparison-placeholder__headline">Texture reveal</span>
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- if before_image != blank and after_image != blank and has_full_comparison -%}
        <button type="button" class="image-comparison__button" aria-label="{{ 'accessibility.drag_to_compare_images' | t }}">
          <span>
            {% render 'icon', icon: 'drag' %}
          </span>
        </button>
      {%- endif -%}
    </image-comparison>
  </div>
</div>

